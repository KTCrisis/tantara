---
import { getCollection } from 'astro:content';
import { STATUT_COLOR, annee } from '../lib/statuts';

interface Props { domain?: string; }
const { domain } = Astro.props;

// chronologie croissante : date de début, puis date de fin (lecture strictement montante)
const claims = (await getCollection('claims'))
  .filter((c) => (domain ? c.data.domain === domain : true))
  .filter((c) => c.data.period)
  .sort((a, b) => a.data.period![0] - b.data.period![0] || a.data.period![1] - b.data.period![1]);
---
<div class="timeline">
  <div class="tl-head">Frise — dérivée des assertions datées</div>
  <div class="tl-list">
    {claims.map((c) => {
      const color = STATUT_COLOR[c.data.statut];
      const [a, b] = c.data.period!;
      return (
        <div class="tl-row">
          <span class="tl-range">{annee(a)} – {annee(b)}</span>
          <span class="tl-marker" style={`background:${color}`}></span>
          <span class="tl-text">{c.data.statement}
            <em class="tl-statut" style={`color:${color}`}>{c.data.statut}</em>
          </span>
        </div>
      );
    })}
  </div>
</div>
