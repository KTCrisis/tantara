---
// Motifs décoratifs à l'encre — SVG tracés main, monochromes (currentColor),
// pensés pour rester discrets (l'appelant fixe couleur + opacité).
interface Props { motif: 'ravenala' | 'filet' | 'frise'; class?: string; }
const { motif, class: klass = '' } = Astro.props;
---
{motif === 'ravenala' && (
  <svg class={klass} viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M50 96 V60" />
    <path d="M50 60 C30 50 18 34 12 16" /><path d="M50 60 C36 48 28 30 26 10" />
    <path d="M50 60 C46 46 44 28 44 8" /><path d="M50 60 C50 44 50 26 50 6" />
    <path d="M50 60 C54 46 56 28 56 8" /><path d="M50 60 C64 48 72 30 74 10" />
    <path d="M50 60 C70 50 82 34 88 16" />
    <path d="M44 62 Q50 57 56 62" />
  </svg>
)}
{motif === 'filet' && (
  <svg class={klass} viewBox="0 0 200 32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M92 16 H42" /><path d="M108 16 H158" />
    <path d="M70 16 q-7 -6 -14 -4" /><path d="M62 16 q-7 6 -14 4" />
    <path d="M130 16 q7 -6 14 -4" /><path d="M138 16 q7 6 14 4" />
    <circle cx="42" cy="16" r="1.6" fill="currentColor" stroke="none" /><circle cx="158" cy="16" r="1.6" fill="currentColor" stroke="none" />
    <g transform="translate(100 16)">
      <circle r="2.6" fill="currentColor" stroke="none" />
      <circle r="5" />
      <path d="M0 -5 V-9" /><path d="M5 0 H9" /><path d="M0 5 V9" /><path d="M-5 0 H-9" />
    </g>
  </svg>
)}
{motif === 'frise' && (
  <svg class={klass} viewBox="0 0 320 28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M6 14 Q36 3 66 14 T126 14" /><path d="M194 14 Q224 3 254 14 T314 14" />
    <path d="M40 9 q-5 -6 -12 -5" /><path d="M92 9 q5 -6 12 -5" />
    <path d="M228 9 q-5 -6 -12 -5" /><path d="M280 9 q5 -6 12 -5" />
    <g transform="translate(160 14)">
      <circle r="2.6" fill="currentColor" stroke="none" /><circle r="5.5" />
      <path d="M0 -5.5 V-10" /><path d="M0 5.5 V10" />
      <path d="M-9 0 q-7 -5 -15 -3" /><path d="M9 0 q7 -5 15 -3" />
    </g>
  </svg>
)}
