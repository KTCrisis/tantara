---
import { getCollection } from 'astro:content';

interface Props { domain?: string; scope?: string; }
const { domain, scope } = Astro.props;

let sources = (await getCollection('sources')).sort((a, b) =>
  (a.data.auteur).localeCompare(b.data.auteur));

// Si un périmètre est donné, ne garder que les sources réellement citées par ses claims.
if (domain || scope) {
  const claims = (await getCollection('claims')).filter((c) =>
    scope ? c.data.scope.some((s) => s.id === scope) : c.data.domain === domain,
  );
  const used = new Set<string>();
  for (const c of claims) {
    c.data.sources.forEach((s) => used.add(s.id));
    c.data.hypotheses.forEach((h) => h.sources.forEach((s) => used.add(s.id)));
  }
  sources = sources.filter((s) => used.has(s.id));
}
---
<ul class="src-list">
  {sources.map((s) => (
    <li id={`src-${s.id}`}>
      <span class="src-tag {s.data.poids}">{s.data.poids}</span>
      {s.data.acces === 'paywall' && <span class="src-tag paywall">paywall</span>}
      <span>
        <strong>{s.data.auteur}</strong>{s.data.annee ? ` (${s.data.annee})` : ''}.
        {' '}{s.data.url ? <a href={s.data.url} target="_blank" rel="noopener">{s.data.titre}</a> : <em>{s.data.titre}</em>}
      </span>
    </li>
  ))}
</ul>
