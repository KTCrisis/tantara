---
import { getCollection } from 'astro:content';
import { ROUTE_COLOR, ROUTE_LABEL } from '../lib/statuts';

interface Props { domain?: string; }
const { domain } = Astro.props;

const points = (await getCollection('claims'))
  .filter((c) => (domain ? c.data.domain === domain : true))
  .filter((c) => c.data.geo)
  .map((c) => ({ ...c.data.geo!, statement: c.data.statement }));

const routesUsed = [...new Set(points.map((p) => p.route).filter(Boolean))] as string[];

// arcs décoratifs (origine → Madagascar) — une évocation, pas une trajectoire attestée
// L'arc Arabie→Sud-Est relaie les traditions d'origine (Zafiraminia, Antemoro) :
// opacité réduite, au rang de récit — l'implantation archéologiquement étayée
// passe par la côte swahili (Kilwa → Mahilaka).
const ARCS = [
  { from: [-2.2, 114.6], to: [-17.5, 49.8], route: 'austronesien', bend: -0.18 },
  { from: [-6.5, 39.5], to: [-17.2, 44.2], route: 'bantou', bend: -0.5 },
  { from: [-8.95, 39.5], to: [-13.7, 48.2], route: 'arabo-swahili', bend: -0.35 },
  { from: [13.5, 44.8], to: [-22.4, 47.85], route: 'arabo-swahili', bend: -0.2, opacity: 0.4 },
  { from: [21.2, 72.85], to: [-15.72, 46.32], route: 'indien', bend: -0.22 },
];

const payload = JSON.stringify({ points, arcs: ARCS, colors: ROUTE_COLOR });
---
<div class="map-wrap">
  <div class="map-osm" data-map={payload} aria-label="Routes de peuplement de Madagascar"></div>
  <div class="map-legend">
    {routesUsed.map((r) => (<span style={`color:${ROUTE_COLOR[r]}`}>route {ROUTE_LABEL[r]}</span>))}
    <span style="color:var(--ink-2)">fond OpenStreetMap — points dérivés des coordonnées des assertions</span>
  </div>
</div>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  // arc quadratique échantillonné entre deux points géographiques
  function arc(from, to, bend, n = 48) {
    const [lat1, lng1] = from, [lat2, lng2] = to;
    const dlat = lat2 - lat1, dlng = lng2 - lng1;
    const clat = (lat1 + lat2) / 2 + bend * dlng;
    const clng = (lng1 + lng2) / 2 - bend * dlat;
    const pts = [];
    for (let i = 0; i <= n; i++) {
      const t = i / n, u = 1 - t;
      pts.push([
        u * u * lat1 + 2 * u * t * clat + t * t * lat2,
        u * u * lng1 + 2 * u * t * clng + t * t * lng2,
      ]);
    }
    return pts;
  }

  for (const el of document.querySelectorAll('.map-osm')) {
    const { points, arcs, colors } = JSON.parse(el.dataset.map);

    const map = L.map(el, { scrollWheelZoom: false, zoomSnap: 0.5 });
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 10,
    }).addTo(map);
    map.fitBounds([[24, 34], [-29, 122]]);

    for (const a of arcs) {
      L.polyline(arc(a.from, a.to, a.bend), {
        color: colors[a.route],
        weight: 2,
        dashArray: '6 5',
        opacity: a.opacity ?? 0.8,
      }).addTo(map);
    }

    for (const p of points) {
      L.circleMarker([p.lat, p.lng], {
        radius: 7,
        color: '#fff',
        weight: 1.5,
        fillColor: p.route ? colors[p.route] : '#6b6256',
        fillOpacity: 1,
      })
        .bindPopup(
          `<strong>${p.label ?? ''}</strong><br>${p.statement}`,
          { maxWidth: 280 },
        )
        .addTo(map);
    }
  }
</script>

<style is:global>
  .map-osm { height: 420px; border-radius: 3px; z-index: 0; }
  /* tirer le fond CARTO vers le papier/encre du site */
  .map-osm .leaflet-tile { filter: sepia(0.22) saturate(0.85); }
  .map-osm .leaflet-popup-content { font-family: var(--sans); font-size: 0.8rem; line-height: 1.45; }
</style>
