---
import '@fontsource-variable/fraunces';
import '@fontsource/spectral/400.css';
import '@fontsource/spectral/400-italic.css';
import '@fontsource/spectral/500.css';
import '@fontsource/spectral/600.css';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import Ornement from '../components/Ornement.astro';
interface Props { title: string; description?: string; }
const { title, description = "L'état des preuves sur le peuplement et l'histoire de Madagascar." } = Astro.props;

const path = Astro.url.pathname.replace(/\/$/, '');
const active = (href: string) => {
  const h = href === '/' ? '' : href;
  return path === h || (h !== '' && path.startsWith(h + '/')) ? 'active' : '';
};
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌍</text></svg>" />
  </head>
  <body>
    <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
    <header class="mobile-bar">
      <a href="/" class="brand-m">tantara<em>.art</em></a>
      <label for="nav-toggle" class="nav-burger" aria-label="Ouvrir le menu"><span></span><span></span><span></span></label>
    </header>
    <label for="nav-toggle" class="nav-scrim" aria-hidden="true"></label>

    <aside class="sidebar">
      <a href="/" class="brand">tantara<em>.art</em></a>
      <nav>
        <a href="/" class={active('/')}>Accueil</a>
        <a href="/methode" class={active('/methode')}>Méthode</a>
        <div class="nav-group">Le récit</div>
        <a href="/geographie" class={active('/geographie')}>Géographie</a>
        <a href="/megafaune" class={active('/megafaune')}>Le monde d'avant</a>
        <a href="/peuplement" class={active('/peuplement')}>Peuplement</a>
        <a href="/traditions-origines" class={active('/traditions-origines')}>Traditions &amp; origines</a>
        <a href="/geographie-historique" class={active('/geographie-historique')}>Géographie historique</a>
        <div class="nav-group">Les acteurs</div>
        <a href="/peuples" class={active('/peuples')}>Les foko</a>
        <a href="/etats" class={active('/etats')}>Les États</a>
        <a href="/lieux" class={active('/lieux')}>Les lieux</a>
        <div class="nav-sep"></div>
        <a href="/regards-exterieurs" class={active('/regards-exterieurs')}>Regards extérieurs</a>
      </nav>
    </aside>

    <div class="content">
      <main>
        <slot />
      </main>
      <footer class="site-foot">
        <Ornement motif="frise" class="foot-frise" />
        <div>tantara.wiki — l'état des preuves, pas le verdict · sources ouvertes quand elles existent</div>
      </footer>
    </div>
  </body>
</html>
