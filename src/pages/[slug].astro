---
// Renderer générique des récits .mdx (modèle hybride) :
// la prose + les composants posés dans le .mdx, puis la bibliographie ajoutée
// automatiquement en pied (seul bloc dont la place n'est pas un choix éditorial).
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import SourceIndex from '../components/SourceIndex.astro';

export async function getStaticPaths() {
  return (await getCollection('pages')).map((p) => ({ params: { slug: p.id }, props: { page: p } }));
}

const { page } = Astro.props;
const { Content } = await render(page);
---
<Base title={`${page.data.title} — tantara.wiki`}>
  <article class="wrap" style="position:relative;">
    {page.data.kicker && (
      <div class="kicker" style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--ocean);margin:60px 0 12px;">{page.data.kicker}</div>
    )}
    <h1>{page.data.title}</h1>
    {page.data.intro && <p class="lead" style="color:var(--ink-2);font-size:1.1rem;">{page.data.intro}</p>}

    <Content />

    <h2 id="sources">Sources</h2>
    <SourceIndex domain={page.data.domain} />
  </article>
</Base>
