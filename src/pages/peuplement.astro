---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Claim from '../components/Claim.astro';
import HypothesisCompare from '../components/HypothesisCompare.astro';
import Timeline from '../components/Timeline.astro';
import MapRoutes from '../components/MapRoutes.astro';
import Registre from '../components/Registre.astro';
import SourceIndex from '../components/SourceIndex.astro';
import { ROUTE_COLOR } from '../lib/statuts';

// Les lignées ancestrales (entités « peuple »), dérivées du scope des assertions.
const lignees = (await getCollection('entities')).filter((e) => e.data.kind === 'peuple');
const claims = await getCollection('claims');
const countScope = (id: string) => claims.filter((c) => c.data.scope.some((s) => s.id === id)).length;
const routeOf: Record<string, string> = { austronesiens: 'austronesien', bantous: 'bantou' };
---
<Base title="Le peuplement de Madagascar — tantara.art">
  <article class="wrap">
    <div class="kicker" style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--ocean);margin:60px 0 12px;">02 · Peuplement</div>
    <h1>Le peuplement de Madagascar</h1>
    <p class="lead" style="color:var(--ink-2);font-size:1.1rem;">
      Deux courants, séparés par tout un océan, qui se rencontrent sur une île longtemps
      vide d'humains. Voici ce que les preuves disent — et où elles s'arrêtent.
    </p>

    <h2>Une double origine</h2>
    <p>
      Le malgache est une langue austronésienne : <Claim id="lexique-austronesien" />
      Pourtant, la population est aussi profondément africaine.
      <Claim id="metissage-recent" />
    </p>

    <h2>Les lignées ancestrales</h2>
    <p>
      Deux apports majeurs, séparés par tout un océan, chacun lisible par des preuves
      différentes — la langue et les cultures pour l'un, les génomes et l'élevage pour
      l'autre. Ce ne sont pas des « ethnies » : ce sont les courants d'où tout le reste
      procède, en deçà des foko.
    </p>
    <div class="lignee-grid">
      {lignees.map((e) => (
        <div class="lignee-card" style={`border-left:3px solid ${ROUTE_COLOR[routeOf[e.id]] ?? 'var(--ocean)'}`}>
          <div class="lignee-nom">{e.data.nom}</div>
          <p class="lignee-resume">{e.data.resume}</p>
          <div class="lignee-count">{countScope(e.id)} assertions rattachées</div>
        </div>
      ))}
    </div>

    <h2>Le registre, par discipline</h2>
    <Registre domain="peuplement" />

    <h2>Un point débattu : la date d'arrivée</h2>
    <p>
      C'est l'exemple type d'une question que le site n'arbitre pas. Les deux lectures,
      avec leur appui :
    </p>
    <HypothesisCompare id="date-arrivee" />

    <h2>Chronologie</h2>
    <Timeline domain="peuplement" />

    <h2>Les routes</h2>
    <MapRoutes domain="peuplement" />

    <h2 id="sources">Sources</h2>
    <SourceIndex />
  </article>
</Base>

<style>
  .lignee-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin: 8px 0 16px; }
  .lignee-card { padding: 14px 18px; background: rgba(0,0,0,0.015); border-radius: 0 4px 4px 0; }
  .lignee-nom { font-weight: 600; font-size: 1.05rem; }
  .lignee-resume { color: var(--ink-2); font-size: 0.9rem; margin: 6px 0 10px; }
  .lignee-count { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--ocean); }
</style>
