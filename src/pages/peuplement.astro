---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Claim from '../components/Claim.astro';
import HypothesisCompare from '../components/HypothesisCompare.astro';
import Timeline from '../components/Timeline.astro';
import MapRoutes from '../components/MapRoutes.astro';
import SourceIndex from '../components/SourceIndex.astro';
import { DISCIPLINES } from '../content.config';

const claims = (await getCollection('claims')).filter((c) => c.data.domain === 'peuplement');
// Le registre est groupé par démarche scientifique : comment on sait, pas ce qu'on croit.
const parDiscipline = DISCIPLINES.map((d) => ({
  discipline: d,
  items: claims.filter((c) => c.data.discipline === d),
})).filter((g) => g.items.length > 0);
---
<Base title="Le peuplement de Madagascar — tantara.art">
  <article class="wrap">
    <div class="kicker" style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--ocean);margin:60px 0 12px;">01 · Peuplement</div>
    <h1>Le peuplement de Madagascar</h1>
    <p class="lead" style="color:var(--ink-2);font-size:1.1rem;">
      Deux courants, séparés par tout un océan, qui se rencontrent sur une île longtemps
      vide d'humains. Voici ce que les preuves disent — et où elles s'arrêtent.
    </p>

    <h2>Une double origine</h2>
    <p>
      Le malgache est une langue austronésienne : <Claim id="lexique-austronesien" />
      Pourtant, la population est aussi profondément africaine.
      <Claim id="metissage-recent" />
    </p>

    <h2>Le registre, par discipline</h2>
    <p>
      Chaque démarche scientifique apporte sa pièce — et son degré de certitude.
      La même histoire, vue par {parDiscipline.length} familles de preuves.
    </p>
    {parDiscipline.map((g) => (
      <section>
        <h3 style="font-family:var(--mono);font-size:0.78rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--ocean);margin:36px 0 8px;">
          {g.discipline} · {g.items.length}
        </h3>
        {g.items.map((c) => <Claim id={c.id} block />)}
      </section>
    ))}

    <h2>Un point débattu : la date d'arrivée</h2>
    <p>
      C'est l'exemple type d'une question que le site n'arbitre pas. Les deux lectures,
      avec leur appui :
    </p>
    <HypothesisCompare id="date-arrivee" />

    <h2>Chronologie</h2>
    <Timeline domain="peuplement" />

    <h2>Les routes</h2>
    <MapRoutes domain="peuplement" />

    <h2 id="sources">Sources</h2>
    <SourceIndex />
  </article>
</Base>
