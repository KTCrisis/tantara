---
import Base from '../layouts/Base.astro';
import MapChrono from '../components/MapChrono.astro';
import Timeline from '../components/Timeline.astro';
import Registre from '../components/Registre.astro';
import SourceIndex from '../components/SourceIndex.astro';
---
<Base title="Regards extérieurs — tantara.art">
  <article class="wrap">
    <div class="kicker" style="font-family:var(--mono);font-size:0.72rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--ocean);margin:60px 0 12px;">03 · Regards extérieurs</div>
    <h1>Qui a décrit l'île, et comment</h1>
    <p class="lead" style="color:var(--ink-2);font-size:1.1rem;">
      Avant le XXe siècle, presque tout ce qui s'écrit sur Madagascar est écrit
      de l'extérieur : par des gouverneurs, des industriels, des naturalistes.
      Cette page ne raconte pas l'île — elle interroge ses <strong>sources</strong>,
      et leurs angles morts.
    </p>

    <h2>Les observateurs, dans le temps et l'espace</h2>
    <p>
      De Fort-Dauphin (1648) aux quarante volumes de Grandidier, chaque foyer
      marque non pas un événement malgache, mais un point de vue posé sur l'île.
    </p>
    <MapChrono domain="regards-exterieurs" start={1870} />

    <h2>Chronologie</h2>
    <Timeline domain="regards-exterieurs" />

    <h2>Le registre, par discipline</h2>
    <Registre domain="regards-exterieurs" />

    <h2 id="sources">Sources</h2>
    <SourceIndex />
  </article>
</Base>
